{
  "name": "recorddrive",
  "version": "2.0.2",
  "description": "A sky-blue team file drive built with Node.js",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "test:security": "node --test test/security-poc.test.js test/authentication-rate-limit-race.test.js test/host-header-confidentiality.test.js test/request-error-confidentiality.test.js",
    "check": "node --check src/server.js && node --check src/app.js"
  },
  "engines": {
    "node": "^22.23.0 || ^24.17.0 || ^26.3.1"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.2",
    "7z-iterator": "2.2.9",
    "xz-compat": "file:vendor/xz-compat-purejs",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "ejs": "6.0.1",
    "exceljs": "^4.4.0",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "helmet": "8.3.0",
    "multer": "2.2.0",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "supertest": "7.2.2"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "7z-iterator": {
      "xz-compat": "$xz-compat"
    }
  }
}
