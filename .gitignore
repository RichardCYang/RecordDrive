# Dependencies
node_modules/

# Local environment files
.env
.env.*
!.env.example

# Runtime data
# The application creates its SQLite database, WAL files, sessions, and uploads here.
data/*
!data/.gitkeep

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test and coverage output
coverage/
.nyc_output/
test-results/

# Build output and caches
dist/
build/
.cache/
.tmp/
temp/
*.tsbuildinfo
.eslintcache

# Editor settings
.vscode/
.idea/
*.swp
*.swo
*~

# Operating system files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# The security-hardened local decoder is a committed runtime dependency.
!vendor/xz-compat-purejs/dist/
!vendor/xz-compat-purejs/dist/**
