PORT=3000
NODE_ENV=development

# In production, replace this with a sufficiently long random value.
SESSION_SECRET=recorddrive-change-this-session-secret-at-least-32-chars

# If no administrator exists on first run, one is created with these values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_DISPLAY_NAME=System Administrator

# Upload limit per file, in MB.
MAX_FILE_SIZE_MB=100
MAX_FILES_PER_UPLOAD=10

# Relative paths are resolved from the project root.
DB_PATH=./data/recorddrive.db
UPLOAD_ROOT=./data/uploads
