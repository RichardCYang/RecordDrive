PORT=3000
HTTP_HOST=0.0.0.0
HTTPS_PORT=3443
HTTPS_HOST=0.0.0.0
NODE_ENV=development

# These values provide the initial TLS settings before an administrator saves settings in the UI.
HTTPS_ENABLED=false
HTTP_TO_HTTPS_REDIRECT=true
TLS_PUBLIC_HOSTNAME=
TLS_CERT_MODE=pem
TLS_CERT_DIRECTORY=
TLS_CERT_PATH=
TLS_KEY_PATH=
TLS_PFX_PATH=
TLS_PASSPHRASE=
TLS_AUTO_RELOAD=true
TLS_RELOAD_INTERVAL_MINUTES=5

# In production, replace this with a sufficiently long random value.
SESSION_SECRET=recorddrive-change-this-session-secret-at-least-32-chars

# If no administrator exists on first run, one is created with these values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_DISPLAY_NAME=System Administrator

# Upload limit per file, in MB.
MAX_FILE_SIZE_MB=100
MAX_FILES_PER_UPLOAD=10

# Relative paths are resolved from the project root.
DB_PATH=./data/recorddrive.db
UPLOAD_ROOT=./data/uploads
