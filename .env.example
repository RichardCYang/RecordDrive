PORT=3000
HTTP_HOST=0.0.0.0
HTTPS_PORT=3443
HTTPS_HOST=0.0.0.0
NODE_ENV=development

# Production rejects requests that are not recognized as HTTPS.
# Keep proxy trust disabled unless every request reaches the app through a known reverse proxy.
# Use a hop count such as 1 or a comma-separated list of trusted IP addresses/subnets.
TRUST_PROXY=false

# Node.js otherwise allows only 5 minutes to receive an entire request body.
# RecordDrive defaults to 1 hour for large uploads. Set 0 only behind a trusted
# reverse proxy that enforces its own request-body timeouts.
HTTP_REQUEST_TIMEOUT_MS=3600000
HTTP_HEADERS_TIMEOUT_MS=60000

# These values provide the initial TLS settings before an administrator saves settings in the UI.
HTTPS_ENABLED=false
HTTP_TO_HTTPS_REDIRECT=true
TLS_PUBLIC_HOSTNAME=
TLS_CERT_MODE=pem
TLS_CERT_DIRECTORY=
TLS_CERT_PATH=
TLS_KEY_PATH=
TLS_PFX_PATH=
TLS_PASSPHRASE=
TLS_AUTO_RELOAD=true
TLS_RELOAD_INTERVAL_MINUTES=5

# In production, use a stable random value of at least 32 UTF-8 bytes.
SESSION_SECRET=recorddrive-change-this-session-secret-at-least-32-chars

# Set this to true, yes, 1, or on to disable administrator creation, login, sessions, privileges, and routes.
ADMIN_ACCESS_DISABLED=false

# If administrator access is enabled and no administrator exists on first run, one is created with these values.
# Use 12 to 128 characters and keep the value within bcrypt's 72-byte UTF-8 input limit.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_DISPLAY_NAME=System Administrator

# Upload and storage quotas are stored in SQLite and managed from Admin > Storage.
# Repository owners can override the per-file and repository-storage defaults from Repository Settings.
# Existing MAX_FILE_SIZE_MB, MAX_FILES_PER_UPLOAD, MAX_REPOSITORY_STORAGE_MB,
# MAX_TOTAL_STORAGE_MB, MAX_REPOSITORY_FILES, and MAX_TOTAL_FILES values are accepted only
# as one-time seed values when the corresponding database settings do not exist.

# Repository record limits prevent authenticated metadata exhaustion.
MAX_REPOSITORIES_PER_USER=1000
MAX_TOTAL_REPOSITORIES=10000

# Bound audit-log storage while retaining the newest records.
MAX_ACTIVITY_LOG_ENTRIES=100000

# Limit concurrent authenticated and pending-MFA sessions for each account.
MAX_SESSIONS_PER_USER=10

# Server-enforced session limits. The idle limit rolls with activity; the absolute limit never does.
SESSION_IDLE_HOURS=12
SESSION_ABSOLUTE_HOURS=168

# Relative paths are resolved from the project root. DB_PATH must remain outside UPLOAD_ROOT.
# UPLOAD_ROOT is the initial value; a saved Admin > Storage setting takes precedence.
DB_PATH=./data/recorddrive.db
UPLOAD_ROOT=./data/uploads

# MFA secrets, temporary recovery-code displays, and saved TLS passphrases use this key source.
# In production, provide at least 32 UTF-8 bytes or omit it to use SESSION_SECRET.
MFA_ENCRYPTION_KEY=
MFA_ISSUER=RecordDrive

# WebAuthn settings must match the exact public origin and relying party host.
# HTTPS is required except for localhost development.
WEBAUTHN_RP_NAME=RecordDrive
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
