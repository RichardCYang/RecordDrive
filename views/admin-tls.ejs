<!doctype html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav') %>
  <main class="page-main">
    <div class="shell">
      <%- include('partials/flash') %>
      <section class="page-hero compact-hero">
        <div>
          <span class="eyebrow">TRANSPORT SECURITY</span>
          <h1>HTTPS and TLS settings</h1>
          <p>Configure RecordDrive to use certificates generated by Posh-ACME on Windows or Linux, redirect HTTP traffic, and reload renewed certificates.</p>
        </div>
      </section>
      <%- include('partials/admin-tabs') %>

      <section class="tls-status-grid">
        <article class="tls-status-card">
          <span class="eyebrow">SAVED CONFIGURATION</span>
          <div class="tls-status-heading">
            <strong><%= settings.httpsEnabled ? 'HTTPS enabled' : 'HTTP only' %></strong>
            <span class="status-pill <%= settings.httpsEnabled ? 'status-ready' : 'status-muted' %>"><%= settings.httpsEnabled ? 'TLS' : 'HTTP' %></span>
          </div>
          <p>HTTP <%= settings.httpHost %>:<%= settings.httpPort %><% if (settings.httpsEnabled) { %> · HTTPS <%= settings.httpsHost %>:<%= settings.httpsPort %><% } %></p>
        </article>

        <article class="tls-status-card">
          <span class="eyebrow">CERTIFICATE STATUS</span>
          <div class="tls-status-heading">
            <strong><%= certificateStatus.status === 'ready' ? 'Certificate ready' : certificateStatus.status === 'error' ? 'Configuration error' : 'Not configured' %></strong>
            <span class="status-pill <%= certificateStatus.status === 'ready' ? 'status-ready' : certificateStatus.status === 'error' ? 'status-error' : 'status-muted' %>"><%= certificateStatus.status.toUpperCase() %></span>
          </div>
          <p><%= certificateStatus.message %></p>
        </article>

        <article class="tls-status-card">
          <span class="eyebrow">ACTIVE LISTENERS</span>
          <div class="tls-status-heading">
            <strong><%= runtimeState ? (runtimeState.httpsEnabled ? 'HTTPS runtime' : 'HTTP runtime') : 'Restart required' %></strong>
            <span class="status-pill <%= runtimeState ? 'status-ready' : 'status-warning' %>"><%= runtimeState ? 'RUNNING' : 'SAVED' %></span>
          </div>
          <% if (runtimeState) { %>
            <p>HTTP :<%= runtimeState.httpPort %><% if (runtimeState.httpsEnabled) { %> · HTTPS :<%= runtimeState.httpsPort %><% } %></p>
          <% } else { %>
            <p>The current process does not expose listener state. Saved settings are applied on the next normal start.</p>
          <% } %>
        </article>
      </section>

      <% if (formError) { %><div class="form-alert tls-form-alert"><%= formError %></div><% } %>

      <form action="/admin/tls" method="post" class="tls-settings-form" data-tls-settings-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <section class="panel tls-panel">
          <div class="panel-header">
            <div><span class="eyebrow">PROTOCOL</span><h2>HTTP and HTTPS listeners</h2></div>
            <p>Listener changes require a RecordDrive restart after saving.</p>
          </div>
          <div class="tls-panel-body">
            <div class="toggle-row">
              <div><strong>Enable HTTPS</strong><small>Start a native Node.js HTTPS listener using the configured Posh-ACME certificate.</small></div>
              <label class="switch-control"><input type="checkbox" name="httpsEnabled" value="1" <%= settings.httpsEnabled ? 'checked' : '' %> data-https-enabled><span aria-hidden="true"></span></label>
            </div>
            <div class="toggle-row" data-https-dependent>
              <div><strong>Redirect HTTP to HTTPS</strong><small>Return a permanent 308 redirect from the HTTP listener instead of serving the application over HTTP.</small></div>
              <label class="switch-control"><input type="checkbox" name="redirectHttpToHttps" value="1" <%= settings.redirectHttpToHttps ? 'checked' : '' %> data-https-redirect><span aria-hidden="true"></span></label>
            </div>

            <div class="tls-form-grid">
              <label class="field"><span>HTTP bind address</span><input type="text" name="httpHost" value="<%= settings.httpHost %>" maxlength="255" required><small>Use <code>0.0.0.0</code> for all IPv4 interfaces or <code>::</code> for IPv6.</small></label>
              <label class="field"><span>HTTP port</span><input type="number" name="httpPort" value="<%= settings.httpPort %>" min="1" max="65535" required></label>
              <label class="field" data-https-dependent><span>HTTPS bind address</span><input type="text" name="httpsHost" value="<%= settings.httpsHost %>" maxlength="255" required></label>
              <label class="field" data-https-dependent><span>HTTPS port</span><input type="number" name="httpsPort" value="<%= settings.httpsPort %>" min="1" max="65535" required></label>
              <label class="field tls-span-2" data-redirect-dependent><span>Public HTTPS host name</span><input type="text" name="publicHostname" value="<%= settings.publicHostname %>" maxlength="255" placeholder="drive.example.com" data-public-hostname><small>Enter only a host name or IP address. Do not include <code>https://</code>, a path, or a port. Wrap IPv6 addresses in brackets.</small></label>
            </div>
          </div>
        </section>

        <section class="panel tls-panel" data-https-dependent>
          <div class="panel-header">
            <div><span class="eyebrow">POSH-ACME CERTIFICATE</span><h2>Certificate files</h2></div>
            <p>PEM mode is recommended for direct use with Posh-ACME output files.</p>
          </div>
          <div class="tls-panel-body">
            <div class="tls-format-selector" role="radiogroup" aria-label="Certificate format">
              <label><input type="radio" name="certificateMode" value="pem" <%= settings.certificateMode === 'pem' ? 'checked' : '' %> data-certificate-mode><span><strong>PEM files</strong><small><code>fullchain.cer</code> + <code>cert.key</code></small></span></label>
              <label><input type="radio" name="certificateMode" value="pfx" <%= settings.certificateMode === 'pfx' ? 'checked' : '' %> data-certificate-mode><span><strong>PFX bundle</strong><small><code>fullchain.pfx</code></small></span></label>
            </div>

            <label class="field"><span>Posh-ACME certificate directory</span><input type="text" name="certificateDirectory" value="<%= settings.certificateDirectory %>" maxlength="4096" placeholder="C:\Users\Administrator\AppData\Local\Posh-ACME\... or /home/user/.config/Posh-ACME/..."><small>Environment variables such as <code>%LOCALAPPDATA%</code>, <code>$HOME</code>, and <code>~</code> are expanded. Relative file names below are resolved from this directory.</small></label>

            <div class="tls-form-grid" data-pem-fields>
              <label class="field"><span>Certificate chain path</span><input type="text" name="certificatePath" value="<%= settings.certificatePath %>" maxlength="4096" placeholder="fullchain.cer"><small>Leave blank to use <code>fullchain.cer</code> in the certificate directory.</small></label>
              <label class="field"><span>Private key path</span><input type="text" name="privateKeyPath" value="<%= settings.privateKeyPath %>" maxlength="4096" placeholder="cert.key"><small>Leave blank to use <code>cert.key</code> in the certificate directory.</small></label>
            </div>

            <div data-pfx-fields>
              <label class="field"><span>PFX bundle path</span><input type="text" name="pfxPath" value="<%= settings.pfxPath %>" maxlength="4096" placeholder="fullchain.pfx"><small>Leave blank to use <code>fullchain.pfx</code> in the certificate directory.</small></label>
            </div>

            <div class="tls-form-grid">
              <label class="field"><span>Private key or PFX passphrase</span><div class="input-with-icon no-leading-icon"><input type="password" name="passphrase" maxlength="1024" autocomplete="new-password" placeholder="<%= hasStoredPassphrase ? 'A passphrase is already stored' : 'Optional' %>" data-password-input><button type="button" class="password-toggle" data-password-toggle>Show</button></div><small>Leave blank to keep the stored passphrase. Posh-ACME uses <code>poshacme</code> as the default PFX password unless it was overridden. The value is stored in the local SQLite settings database.</small></label>
              <label class="check-card"><input type="checkbox" name="clearPassphrase" value="1"><span><strong>Clear stored passphrase</strong><small>Use this when the private key or PFX file no longer requires a passphrase.</small></span></label>
            </div>

            <div class="resolved-paths">
              <div><span>Resolved certificate</span><code><%= certificateStatus.resolvedPaths.certificatePath || 'Not used in PFX mode' %></code></div>
              <div><span>Resolved private key</span><code><%= certificateStatus.resolvedPaths.privateKeyPath || 'Not used in PFX mode' %></code></div>
              <div><span>Resolved PFX</span><code><%= certificateStatus.resolvedPaths.pfxPath || 'Not used in PEM mode' %></code></div>
            </div>
          </div>
        </section>

        <section class="panel tls-panel" data-https-dependent>
          <div class="panel-header"><div><span class="eyebrow">RENEWAL</span><h2>Certificate reload</h2></div></div>
          <div class="tls-panel-body">
            <div class="toggle-row">
              <div><strong>Automatically reload renewed certificate files</strong><small>RecordDrive checks file modification times and replaces the active TLS context without interrupting existing connections.</small></div>
              <label class="switch-control"><input type="checkbox" name="autoReloadCertificate" value="1" <%= settings.autoReloadCertificate ? 'checked' : '' %> data-auto-reload><span aria-hidden="true"></span></label>
            </div>
            <label class="field tls-interval-field" data-reload-dependent><span>Reload check interval in minutes</span><input type="number" name="reloadIntervalMinutes" value="<%= settings.reloadIntervalMinutes %>" min="1" max="1440" required><small>Posh-ACME can renew files in place; the active certificate is updated when a file change is detected.</small></label>

            <% if (certificateStatus.certificate) { %>
              <dl class="certificate-details">
                <div><dt>Subject</dt><dd><%= certificateStatus.certificate.subject %></dd></div>
                <div><dt>Issuer</dt><dd><%= certificateStatus.certificate.issuer %></dd></div>
                <div><dt>Valid from</dt><dd><%= formatDate(certificateStatus.certificate.validFrom) %></dd></div>
                <div><dt>Valid until</dt><dd><%= formatDate(certificateStatus.certificate.validTo) %> · <%= certificateStatus.certificate.daysRemaining %> days remaining</dd></div>
                <div><dt>SHA-256 fingerprint</dt><dd><code><%= certificateStatus.certificate.fingerprint256 %></code></dd></div>
              </dl>
            <% } %>
          </div>
        </section>

        <div class="tls-action-bar">
          <div><strong>Save and validate</strong><span>Certificate files are parsed and the private key is checked before HTTPS settings are accepted.</span></div>
          <button class="button button-primary" type="submit">Save HTTPS settings</button>
        </div>
      </form>

      <% if (settings.httpsEnabled) { %>
        <section class="panel tls-reload-panel">
          <div class="panel-header">
            <div><span class="eyebrow">LIVE OPERATION</span><h2>Reload the active certificate</h2></div>
            <form action="/admin/tls/reload" method="post">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="button button-secondary" type="submit" <%= canReloadCertificate ? '' : 'disabled' %>>Reload certificate now</button>
            </form>
          </div>
          <div class="tls-live-note">This operation reloads certificate content only. Enabling HTTPS, changing listener addresses or ports, changing redirect behavior, switching PEM/PFX mode, and enabling a previously inactive automatic reload schedule require a process restart.</div>
        </section>
      <% } %>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
