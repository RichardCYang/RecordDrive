<header class="topbar">
  <div class="shell topbar-inner">
    <a class="brand" href="/" aria-label="<%= t('RecordDrive home') %>">
      <%- include('logo') %>
    </a>

    <nav class="main-nav" aria-label="<%= t('Primary navigation') %>">
      <a class="nav-link <%= currentPath === '/' || currentPath.startsWith('/repositories') ? 'is-active' : '' %>" href="/"><%= t('My Drive') %></a>
      <% if (currentUser?.role === 'ADMIN' && !administratorAccessDisabled) { %>
        <a class="nav-link <%= currentPath.startsWith('/admin') ? 'is-active' : '' %>" href="/admin"><%= t('Admin') %></a>
      <% } %>
      <a class="nav-link <%= currentPath.startsWith('/settings') ? 'is-active' : '' %>" href="/settings"><%= t('Settings') %></a>
    </nav>

    <div class="account-area">
      <a class="account-badge account-badge-link" href="/settings" aria-label="<%= t('Settings') %>">
        <span class="avatar"><%= currentUser.display_name.slice(0, 1).toUpperCase() %></span>
        <span class="account-text">
          <strong><%= currentUser.display_name %></strong>
          <small><%= currentUser.role === 'ADMIN' && !administratorAccessDisabled ? t('Administrator') : `@${currentUser.username}` %></small>
        </span>
      </a>
      <form action="/logout" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="icon-button" type="submit" title="<%= t('Sign out') %>" aria-label="<%= t('Sign out') %>">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 4H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h5M14 8l4 4-4 4M18 12H8"/></svg>
        </button>
      </form>
    </div>
  </div>
</header>
