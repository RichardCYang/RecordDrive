<!doctype html>
<html lang="<%= language %>">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav') %>
  <main class="page-main">
    <div class="shell settings-shell">
      <%- include('partials/flash') %>
      <section class="page-hero compact-hero">
        <div>
          <a class="back-link" href="/repositories/<%= repository.id %>"><%= t('← Back') %></a>
          <span class="eyebrow"><%= t('REPOSITORY SETTINGS') %></span>
          <h1><%= t('{{name}} settings', { name: repository.name }) %></h1>
          <p><%= t('Set repository-specific upload and storage limits. Changes apply to new uploads immediately.') %></p>
        </div>
        <a class="button button-secondary" href="/repositories/<%= repository.id %>"><%= t('Open repository') %></a>
      </section>

      <section class="storage-status-grid quota-status-grid">
        <article class="storage-status-card">
          <span class="metric-label"><%= t('Stored data') %></span>
          <strong><%= formatBytes(usage.bytes) %></strong>
          <small><%= usage.files %> <%= Number(usage.files) === 1 ? t('file') : t('files') %></small>
        </article>
        <article class="storage-status-card">
          <span class="metric-label"><%= t('Active repository quota') %></span>
          <strong><%= quotaSettings.effective.maxRepositoryStorageMb > 0 ? `${quotaSettings.effective.maxRepositoryStorageMb} MB` : t('Unlimited') %></strong>
          <small><%= quotaSettings.overrides.maxRepositoryStorageMb === null ? t('Using the administrator default') : t('Repository override') %></small>
        </article>
        <article class="storage-status-card">
          <span class="metric-label"><%= t('Active per-file limit') %></span>
          <strong><%= quotaSettings.effective.maxFileSizeMb > 0 ? `${quotaSettings.effective.maxFileSizeMb} MB` : t('Unlimited') %></strong>
          <small><%= quotaSettings.overrides.maxFileSizeMb === null ? t('Using the administrator default') : t('Repository override') %></small>
        </article>
      </section>

      <form action="/repositories/<%= repository.id %>/settings" method="post" class="stack-form repository-settings-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <section class="panel">
          <div class="panel-header">
            <div>
              <span class="eyebrow"><%= t('UPLOAD AND STORAGE') %></span>
              <h2><%= t('Repository-specific limits') %></h2>
            </div>
            <strong class="status-pill status-success"><%= t('Applies immediately') %></strong>
          </div>
          <div class="settings-panel-body">
            <div class="quota-settings-grid">
              <label class="field">
                <span><%= t('Maximum size per file (MB)') %></span>
                <input
                  type="number"
                  name="maxFileSizeMb"
                  min="0"
                  max="10240"
                  step="1"
                  inputmode="numeric"
                  value="<%= quotaSettings.overrides.maxFileSizeMb ?? '' %>"
                  placeholder="<%= quotaSettings.global.maxFileSizeMb %>"
                >
                <small><%= t('Leave blank to use the administrator default of {{value}} MB. Enter 0 for unlimited.', { value: quotaSettings.global.maxFileSizeMb }) %></small>
              </label>

              <label class="field">
                <span><%= t('Repository storage quota (MB)') %></span>
                <input
                  type="number"
                  name="maxRepositoryStorageMb"
                  min="0"
                  max="1048576"
                  step="1"
                  inputmode="numeric"
                  value="<%= quotaSettings.overrides.maxRepositoryStorageMb ?? '' %>"
                  placeholder="<%= quotaSettings.global.maxRepositoryStorageMb %>"
                >
                <small><%= t('Leave blank to use the administrator default of {{value}} MB. Enter 0 for unlimited.', { value: quotaSettings.global.maxRepositoryStorageMb }) %></small>
              </label>
            </div>

            <div class="storage-warning quota-warning">
              <strong><%= t('Server-wide limits still apply') %></strong>
              <span><%= t('An administrator can enforce total service storage and file-count limits. Lowering a quota below current usage does not delete files; it blocks new uploads until usage is below the limit.') %></span>
            </div>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <div>
              <span class="eyebrow"><%= t('FILE METADATA') %></span>
              <h2><%= t('File access time') %></h2>
            </div>
            <strong class="status-pill <%= repository.update_file_access_time ? 'status-success' : 'status-neutral' %>">
              <%= repository.update_file_access_time ? t('Access time updates are enabled') : t('Access time updates are disabled') %>
            </strong>
          </div>
          <div class="settings-panel-body">
            <label class="field">
              <span><%= t('Access time behavior') %></span>
              <select name="fileAccessTimePolicy" required>
                <option value="enabled" <%= repository.update_file_access_time ? 'selected' : '' %>><%= t('Use') %></option>
                <option value="disabled" <%= repository.update_file_access_time ? '' : 'selected' %>><%= t('Do not use') %></option>
              </select>
              <small><%= t('Choose whether a web download or supported preview updates the stored file access time.') %></small>
            </label>
          </div>
        </section>

        <div class="storage-action-bar">
          <div>
            <strong><%= t('Save and apply now') %></strong>
            <span><%= t('The next upload request reads these values directly from the database.') %></span>
          </div>
          <button class="button button-primary" type="submit"><%= t('Save repository settings') %></button>
        </div>
      </form>

      <section class="panel">
        <div class="panel-header">
          <div>
            <span class="eyebrow"><%= t('LOCAL NETWORK') %></span>
            <h2><%= t('Windows SMB access') %></h2>
          </div>
          <strong class="status-pill <%= smbSettings.enabled ? 'status-success' : 'status-neutral' %>">
            <%= smbSettings.enabled ? t('SMB access is enabled') : t('SMB access is disabled') %>
          </strong>
        </div>
        <div class="settings-panel-body">
          <% if (!smbSettings.available) { %>
            <div class="storage-warning quota-warning">
              <strong><%= t('SMB service is not available') %></strong>
              <span><%= t('An administrator must enable the SMB sidecar and shared-volume settings before a repository can be published on the local network.') %></span>
            </div>
          <% } else { %>
            <% if (!smbSettings.runtimeReady) { %>
              <div class="storage-warning quota-warning">
                <strong><%= t('SMB sidecar is not ready') %></strong>
                <span><%= t('Start the Samba sidecar and wait for its runtime status before enabling this repository.') %></span>
              </div>
            <% } else if (!smbSettings.xattrSupported) { %>
              <div class="storage-warning quota-warning">
                <strong><%= t('Exact Windows creation-time storage is unavailable') %></strong>
                <span><%= t('The SMB projection filesystem must support user extended attributes before this repository can be enabled.') %></span>
              </div>
            <% } %>
            <div class="security-overview-grid">
              <div class="security-overview-item">
                <span><%= t('Windows path') %></span>
                <strong><code><%= smbSettings.uncPath %></code></strong>
                <small><%= t('Enter this path in the Windows File Explorer address bar.') %></small>
              </div>
              <div class="security-overview-item">
                <span><%= t('SMB username') %></span>
                <strong><code><%= smbSettings.username %></code></strong>
                <small><%= t('The SMB password is separate from the RecordDrive sign-in password.') %></small>
              </div>
              <div class="security-overview-item">
                <span><%= t('Timestamp mode') %></span>
                <strong><%= t('Creation, modification, and access times') %></strong>
                <small><%= t('RecordDrive uses inode-preserving hard links and Samba extended attributes so timestamps supplied by the Windows client are not rewritten by synchronization.') %></small>
              </div>
            </div>

            <form action="/repositories/<%= repository.id %>/settings/smb" method="post" class="stack-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label class="field checkbox-field">
                <input type="checkbox" name="smbEnabled" value="1" <%= smbSettings.enabled ? 'checked' : '' %>>
                <span><%= t('Enable SMB access for this repository') %></span>
                <small><%= t('Only the repository owner or a server administrator can change this setting.') %></small>
              </label>
              <label class="field checkbox-field">
                <input type="checkbox" name="smbReadOnly" value="1" <%= smbSettings.readOnly ? 'checked' : '' %>>
                <span><%= t('Publish as read-only') %></span>
                <small><%= t('Leave this off to allow copying, moving, renaming, editing, and deleting files from Windows.') %></small>
              </label>
              <label class="field">
                <span><%= smbSettings.credentialConfigured ? t('Reset SMB password') : t('Set SMB password') %></span>
                <input
                  type="password"
                  name="smbPassword"
                  minlength="12"
                  maxlength="127"
                  autocomplete="new-password"
                >
                <small><%= smbSettings.credentialConfigured
                  ? t('Leave blank to keep the current SMB password. Enter a new value to rotate it.')
                  : t('Use 12-127 characters. The password is transferred once to the Samba sidecar and is not stored in the application database.') %></small>
              </label>
              <div class="storage-warning quota-warning">
                <strong><%= t('Windows Explorer copy behavior') %></strong>
                <span><%= t('The SMB server preserves every timestamp value sent by Windows. Standard Explorer copy may create a new creation/access time; use the bundled RecordDrive timestamp-preserving copy tool when all three source times must match exactly.') %></span>
              </div>
              <div class="storage-action-bar">
                <div>
                  <strong><%= t('Apply SMB settings') %></strong>
                  <span><%= t('Changes are published to the Samba service without restarting RecordDrive.') %></span>
                </div>
                <button class="button button-primary" type="submit"><%= t('Save SMB settings') %></button>
              </div>
            </form>
          <% } %>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header">
          <div>
            <span class="eyebrow"><%= t('ACCESS') %></span>
            <h2><%= t('Who can change these settings') %></h2>
          </div>
        </div>
        <div class="settings-panel-body">
          <div class="security-overview-grid">
            <div class="security-overview-item">
              <span><%= t('Owner') %></span>
              <strong><%= t('Repository control') %></strong>
              <small><%= t('The repository owner can set custom file-size and storage limits at any time.') %></small>
            </div>
            <div class="security-overview-item">
              <span><%= t('Administrator') %></span>
              <strong><%= t('Full control') %></strong>
              <small><%= t('Administrators can change both repository overrides and server-wide defaults.') %></small>
            </div>
            <div class="security-overview-item">
              <span><%= t('Shared users') %></span>
              <strong><%= t('No settings access') %></strong>
              <small><%= t('Shared users cannot view or modify repository settings.') %></small>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
