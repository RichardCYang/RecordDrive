<!doctype html>
<html lang="<%= language %>">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav') %>
  <main class="page-main">
    <div class="shell settings-shell password-change-shell">
      <%- include('partials/flash') %>
      <section class="page-hero compact-hero">
        <div>
          <span class="eyebrow"><%= t('ACCOUNT SECURITY') %></span>
          <h1><%= t('Change password') %></h1>
          <p><%= forced
            ? t('Replace the temporary password before accessing files, repositories, or account settings.')
            : t('Use a unique password that you do not use for another service.') %></p>
        </div>
        <% if (forced) { %>
          <strong class="status-pill status-warning"><%= t('Required now') %></strong>
        <% } %>
      </section>

      <section class="panel password-change-panel">
        <div class="panel-header">
          <div>
            <span class="eyebrow"><%= t('PASSWORD') %></span>
            <h2><%= forced ? t('Replace temporary password') : t('Set a new password') %></h2>
          </div>
          <p><%= t('Changing your password signs out every other active session for this account.') %></p>
        </div>
        <div class="settings-panel-body">
          <% if (error) { %><div class="form-alert" role="alert"><%= error %></div><% } %>
          <form action="/settings/password" method="post" class="stack-form password-change-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label class="field">
              <span><%= t('Current password') %></span>
              <div class="input-with-icon no-leading-icon">
                <input type="password" name="currentPassword" autocomplete="current-password" maxlength="1024" required data-password-input autofocus>
                <button type="button" class="password-toggle" aria-label="<%= t('Show password') %>" data-password-toggle><%= t('Show') %></button>
              </div>
            </label>
            <label class="field">
              <span><%= t('New password') %></span>
              <div class="input-with-icon no-leading-icon">
                <input type="password" name="newPassword" autocomplete="new-password" minlength="<%= minimumPasswordLength %>" maxlength="<%= maximumPasswordLength %>" required data-password-input>
                <button type="button" class="password-toggle" aria-label="<%= t('Show password') %>" data-password-toggle><%= t('Show') %></button>
              </div>
              <small><%= t('Use {{minimum}} to {{maximum}} characters and keep the password within 72 UTF-8 bytes.', { minimum: minimumPasswordLength, maximum: maximumPasswordLength }) %></small>
            </label>
            <label class="field">
              <span><%= t('Confirm new password') %></span>
              <div class="input-with-icon no-leading-icon">
                <input type="password" name="confirmPassword" autocomplete="new-password" minlength="<%= minimumPasswordLength %>" maxlength="<%= maximumPasswordLength %>" required data-password-input>
                <button type="button" class="password-toggle" aria-label="<%= t('Show password') %>" data-password-toggle><%= t('Show') %></button>
              </div>
            </label>
            <button class="button button-primary button-block" type="submit"><%= t('Change password') %></button>
          </form>
        </div>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
