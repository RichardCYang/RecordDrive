<%
  const kindLabels = {
    image: t('Image'),
    video: t('Video'),
    audio: t('Audio'),
    archive: t('Archive'),
    sheet: t('Spreadsheet'),
    slide: t('Presentation'),
    pdf: t('PDF document'),
    document: t('Document'),
    file: t('File')
  };
  const kindCodes = {
    image: 'IMG',
    video: 'VID',
    audio: 'AUD',
    archive: 'ZIP',
    sheet: 'XLS',
    slide: 'PPT',
    pdf: 'PDF',
    document: 'DOC',
    file: 'FILE'
  };
  const counts = files.reduce((result, file) => {
    const kind = fileKind(file.mime_type, file.original_name);
    result[kind] = (result[kind] || 0) + 1;
    return result;
  }, {});
  const documentCount = (counts.document || 0) + (counts.pdf || 0) + (counts.sheet || 0) + (counts.slide || 0);
  const mediaCount = (counts.video || 0) + (counts.audio || 0);
  const otherCount = (counts.file || 0);
%>
<!doctype html>
<html lang="<%= language %>">
<head><%- include('partials/head') %></head>
<body class="explorer-page">
  <%- include('partials/nav') %>

  <main class="explorer-main" data-file-explorer>
    <div class="explorer-shell">
      <%- include('partials/flash') %>

      <section class="explorer-window" aria-label="<%= repository.name %> <%= t('File list') %>">
        <header class="explorer-titlebar">
          <div class="explorer-repository-identity">
            <a class="explorer-back-button" href="/" aria-label="<%= t('Back') %>" title="<%= t('Back') %>">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            </a>
            <span class="explorer-repository-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M3 7h7l2 2h9v10H3z"/><path d="M3 7V5h7l2 2"/></svg>
            </span>
            <div class="explorer-repository-copy">
              <div class="explorer-title-line">
                <h1><%= repository.name %></h1>
                <span class="explorer-access-badge"><%= repositoryPermissions.source === 'ADMIN' ? t('Administrator access') : repositoryPermissions.source === 'OWNER' ? t('Owner access') : t('Shared access') %></span>
              </div>
              <p><%= repository.description || t('Manage the files in this repository securely.') %></p>
            </div>
          </div>

          <div class="explorer-title-actions">
            <div class="explorer-stat-pills" aria-label="<%= t('Repository summary') %>">
              <span><%= stats.file_count === 1 ? t('{{count}} file', { count: stats.file_count }) : t('{{count}} files', { count: stats.file_count }) %></span>
              <span><%= t('{{size}} used', { size: formatBytes(stats.total_size) }) %></span>
              <span><%= grants.length === 1 ? t('{{count}} shared user', { count: grants.length }) : t('{{count}} shared users', { count: grants.length }) %></span>
            </div>
            <% if (repositoryPermissions.canManage) { %>
              <a class="explorer-icon-action" href="/repositories/<%= repository.id %>/settings" title="<%= t('Repository settings') %>" aria-label="<%= t('Repository settings') %>" data-repository-settings>
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1-2.8 2.8-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2h-4V21a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1L4.2 17l.1-.1a1.7 1.7 0 0 0 .3-1.9A1.7 1.7 0 0 0 3 14H2.8v-4H3a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9L4.2 7 7 4.2l.1.1A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-1.6v-.2h4V3a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1L19.8 7l-.1.1a1.7 1.7 0 0 0-.3 1.9 1.7 1.7 0 0 0 1.6 1h.2v4H21a1.7 1.7 0 0 0-1.6 1Z"/></svg>
              </a>
              <a class="explorer-icon-action" href="/repositories/<%= repository.id %>/permissions" title="<%= t('Manage permissions') %>" aria-label="<%= t('Manage permissions') %>">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M19 8v6M22 11h-6"/></svg>
              </a>
            <% } %>
            <% if (repositoryPermissions.canManage) { %>
              <form action="/repositories/<%= repository.id %>/delete" method="post" data-confirm="<%= t('Permanently delete this repository and every stored file? This action cannot be undone.') %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="explorer-icon-action explorer-icon-danger" type="submit" title="<%= t('Delete repository') %>" aria-label="<%= t('Delete repository') %>">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>
                </button>
              </form>
            <% } %>
          </div>
        </header>

        <div class="explorer-addressbar">
          <div class="explorer-nav-controls" aria-label="<%= t('Navigation controls') %>">
            <a href="/" class="explorer-square-button" title="<%= t('Back') %>" aria-label="<%= t('Back') %>">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            </a>
            <button type="button" class="explorer-square-button" data-refresh-button title="<%= t('Refresh') %>" aria-label="<%= t('Refresh') %>">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 11a8.1 8.1 0 1 0 .2 4M20 4v7h-7"/></svg>
            </button>
          </div>

          <nav class="explorer-breadcrumb" aria-label="<%= t('Current location') %>">
            <a href="/">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h7l2 2h9v10H3z"/></svg>
              <%= t('My Drive') %>
            </a>
            <svg class="breadcrumb-separator" viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            <span><%= repository.name %></span>
          </nav>

          <form action="/repositories/<%= repository.id %>" method="get" class="explorer-search" role="search">
            <input type="hidden" name="sort" value="<%= sort %>">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
            <input type="search" name="q" value="<%= search %>" placeholder="<%= t('Search in {{name}}', { name: repository.name }) %>" aria-label="<%= t('Search repository files') %>" data-explorer-search>
            <% if (search) { %>
              <a href="/repositories/<%= repository.id %>?sort=<%= sort %>" aria-label="<%= t('Clear search') %>" title="<%= t('Clear search') %>">×</a>
            <% } %>
          </form>
        </div>

        <div class="explorer-commandbar">
          <div class="explorer-command-group">
            <% if (repositoryPermissions.upload) { %>
              <button class="explorer-command explorer-command-primary" type="button" data-upload-open>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <span><%= t('Upload files') %></span>
              </button>
            <% } %>
            <% if (repositoryPermissions.upload && (repositoryPermissions.download || repositoryPermissions.delete)) { %><span class="explorer-command-divider" aria-hidden="true"></span><% } %>
            <% if (repositoryPermissions.download) { %>
              <a class="explorer-command is-disabled" href="#" data-selected-download aria-disabled="true" tabindex="-1">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"/></svg>
                <span><%= t('Download') %></span>
              </a>
            <% } %>
            <% if (repositoryPermissions.delete) { %>
              <form action="#" method="post" data-selected-delete-form data-confirm="<%= t('Permanently delete the selected file?') %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="explorer-command is-disabled" type="submit" data-selected-delete disabled>
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v5M14 11v5"/></svg>
                  <span><%= t('Delete') %></span>
                </button>
              </form>
            <% } %>
            <% if (!repositoryPermissions.upload && !repositoryPermissions.download && !repositoryPermissions.delete) { %>
              <span class="explorer-readonly-label"><%= t('View-only access') %></span>
            <% } %>
          </div>

          <div class="explorer-command-group explorer-command-group-right">
            <span class="explorer-selection-label" data-selection-label><%= t('No item selected') %></span>
            <form action="/repositories/<%= repository.id %>" method="get" class="explorer-sort-form">
              <% if (search) { %><input type="hidden" name="q" value="<%= search %>"><% } %>
              <label>
                <span class="sr-only"><%= t('Sort by') %></span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h10M4 12h7M4 17h4M17 5v14m0 0-3-3m3 3 3-3"/></svg>
                <select name="sort" data-sort-select aria-label="<%= t('Sort files') %>">
                  <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>><%= t('Newest first') %></option>
                  <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>><%= t('Oldest first') %></option>
                  <option value="name-asc" <%= sort === 'name-asc' ? 'selected' : '' %>><%= t('Name A–Z') %></option>
                  <option value="name-desc" <%= sort === 'name-desc' ? 'selected' : '' %>><%= t('Name Z–A') %></option>
                  <option value="size-desc" <%= sort === 'size-desc' ? 'selected' : '' %>><%= t('Largest first') %></option>
                  <option value="size-asc" <%= sort === 'size-asc' ? 'selected' : '' %>><%= t('Smallest first') %></option>
                </select>
              </label>
            </form>
            <div class="explorer-view-switch" role="group" aria-label="<%= t('File view') %>">
              <button type="button" class="is-active" data-view-mode="list" title="<%= t('List view') %>" aria-label="<%= t('List view') %>" aria-pressed="true">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
              </button>
              <button type="button" data-view-mode="grid" title="<%= t('Icon view') %>" aria-label="<%= t('Icon view') %>" aria-pressed="false">
                <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              </button>
            </div>
          </div>
        </div>

        <% if (repositoryPermissions.upload) { %>
        <section class="explorer-upload-drawer" data-upload-drawer hidden aria-label="<%= t('File upload') %>">
          <div class="explorer-upload-heading">
            <div>
              <span class="eyebrow"><%= t('UPLOAD') %></span>
              <h2><%= t('Add files to this repository') %></h2>
              <p><%= t('Drag files here or choose them from your device.') %></p>
            </div>
            <button type="button" class="explorer-square-button" data-upload-close aria-label="<%= t('Close upload panel') %>" title="<%= t('Close upload panel') %>">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"/></svg>
            </button>
          </div>
          <form action="/repositories/<%= repository.id %>/upload" method="post" enctype="multipart/form-data" data-upload-form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label class="drop-zone explorer-drop-zone" data-drop-zone>
              <input type="file" name="files" multiple required data-file-input>
              <span class="upload-cloud" aria-hidden="true">
                <svg viewBox="0 0 64 64"><path d="M18 49h31a11 11 0 0 0 1-22 17 17 0 0 0-32-4A13 13 0 0 0 18 49Z"/><path d="m24 34 8-8 8 8M32 27v17"/></svg>
              </span>
              <span class="drop-copy">
                <strong><%= t('Drop files here') %></strong>
                <small><%= t('Up to {{size}} MB per file · Up to {{count}} files at a time', { size: maxFileSizeMb, count: maxFilesPerUpload }) %></small>
              </span>
              <span class="button button-primary button-small"><%= t('Choose from device') %></span>
            </label>
            <div class="selected-files" data-selected-files hidden></div>
            <div class="upload-submit-row" data-upload-submit hidden>
              <span data-upload-summary></span>
              <button class="button button-primary" type="submit"><%= t('Upload selected files') %></button>
            </div>
          </form>
        </section>
        <% } %>

        <div class="explorer-body">
          <aside class="explorer-sidebar" aria-label="<%= t('File categories') %>">
            <div class="explorer-sidebar-section">
              <span class="explorer-sidebar-title"><%= t('This repository') %></span>
              <button type="button" class="explorer-sidebar-item is-active" data-file-filter="all" aria-pressed="true">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h7l2 2h9v10H3z"/></svg>
                <span><%= t('All files') %></span><strong><%= files.length %></strong>
              </button>
              <button type="button" class="explorer-sidebar-item" data-file-filter="image" aria-pressed="false">
                <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                <span><%= t('Images') %></span><strong><%= counts.image || 0 %></strong>
              </button>
              <button type="button" class="explorer-sidebar-item" data-file-filter="document,pdf,sheet,slide" aria-pressed="false">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M8 13h8M8 17h6"/></svg>
                <span><%= t('Documents') %></span><strong><%= documentCount %></strong>
              </button>
              <button type="button" class="explorer-sidebar-item" data-file-filter="video,audio" aria-pressed="false">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 10 4.5-2.5v9L15 14M5 6h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z"/></svg>
                <span><%= t('Media') %></span><strong><%= mediaCount %></strong>
              </button>
              <button type="button" class="explorer-sidebar-item" data-file-filter="archive" aria-pressed="false">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 3h16v18H4zM8 3v4h4V3M8 11h4M8 15h4"/></svg>
                <span><%= t('Archives') %></span><strong><%= counts.archive || 0 %></strong>
              </button>
              <% if (otherCount) { %>
                <button type="button" class="explorer-sidebar-item" data-file-filter="file" aria-pressed="false">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                  <span><%= t('Other') %></span><strong><%= otherCount %></strong>
                </button>
              <% } %>
            </div>

            <div class="explorer-storage-card">
              <div class="explorer-storage-heading"><span><%= t('Storage used') %></span><strong><%= formatBytes(stats.total_size) %></strong></div>
              <div class="explorer-storage-track"><span style="width: <%= Math.min(100, Math.max(4, stats.total_size ? 18 : 0)) %>%"></span></div>
              <small><%= stats.file_count === 1 ? t('{{count}} file is stored in this repository.', { count: stats.file_count }) : t('{{count}} files are stored in this repository.', { count: stats.file_count }) %></small>
            </div>

            <div class="explorer-members-card">
              <div class="explorer-members-heading"><span><%= t('Shared users') %></span><strong><%= grants.length %></strong></div>
              <div class="explorer-member-list">
                <% grants.slice(0, 4).forEach((grant) => { %>
                  <div class="explorer-member">
                    <span class="avatar"><%= grant.display_name.slice(0, 1).toUpperCase() %></span>
                    <span><strong><%= grant.display_name %></strong><small>@<%= grant.username %></small></span>
                  </div>
                <% }) %>
              </div>
              <% if (repositoryPermissions.canManage) { %>
                <a href="/repositories/<%= repository.id %>/permissions"><%= t('Manage permissions') %></a>
              <% } %>
            </div>
          </aside>

          <section class="explorer-content" aria-label="<%= t('File list') %>">
            <div class="explorer-content-heading">
              <div>
                <h2 data-current-category><%= search ? t('Search results for “{{search}}”', { search }) : t('All files') %></h2>
                <span><strong data-visible-file-count><%= files.length %></strong> <span data-visible-item-label><%= files.length === 1 ? t('item') : t('items') %></span></span>
              </div>
              <% if (search) { %><span class="explorer-search-chip"><%= t('Search:') %> <strong><%= search %></strong></span><% } %>
            </div>

            <% if (files.length) { %>
              <div class="explorer-list-header" data-list-header>
                <span></span>
                <span><%= t('Name') %></span>
                <span><%= t('Uploaded') %></span>
                <span><%= t('Type') %></span>
                <span><%= t('Size') %></span>
                <span><%= t('Uploader') %></span>
                <span></span>
              </div>

              <div class="explorer-file-items" data-file-items data-view="list">
                <% files.forEach((file) => {
                  const kind = fileKind(file.mime_type, file.original_name);
                  const owner = file.uploader_name || t('Deleted account');
                  const downloadUrl = repositoryPermissions.download ? `/repositories/${repository.id}/files/${file.id}/download` : '';
                  const deleteUrl = repositoryPermissions.delete ? `/repositories/${repository.id}/files/${file.id}/delete` : '';
                  const previewKind = filePreviewKind(file.mime_type, file.original_name);
                  const previewUrl = repositoryPermissions.download && previewKind
                    ? `/repositories/${repository.id}/files/${file.id}/preview`
                    : '';
                %>
                  <article
                    class="explorer-file-item"
                    tabindex="0"
                    data-file-item
                    data-file-id="<%= file.id %>"
                    data-file-name="<%= file.original_name %>"
                    data-file-kind="<%= kind %>"
                    data-file-type="<%= kindLabels[kind] || t('File') %>"
                    data-file-size="<%= formatBytes(file.size) %>"
                    data-file-mime="<%= file.mime_type %>"
                    data-file-owner="<%= owner %>"
                    data-file-date="<%= formatDate(file.created_at) %>"
                    data-download-url="<%= downloadUrl %>"
                    data-delete-url="<%= deleteUrl %>"
                    data-preview-kind="<%= previewKind %>"
                    data-preview-url="<%= previewUrl %>"
                    aria-label="<%= file.original_name %>, <%= formatBytes(file.size) %>">
                    <label class="explorer-file-check" title="<%= t('Select') %>">
                      <input type="checkbox" data-file-select aria-label="<%= t('Select {{name}}', { name: file.original_name }) %>">
                      <span></span>
                    </label>

                    <a class="explorer-file-primary" href="<%= downloadUrl || '#' %>" data-file-primary title="<%= repositoryPermissions.download ? t('Click once to select; double-click to download') : t('Click to select') %>">
                      <span class="file-icon explorer-file-icon file-<%= kind %>" aria-hidden="true"><%= kindCodes[kind] || 'FILE' %></span>
                      <span class="explorer-file-copy">
                        <strong><%= file.original_name %></strong>
                        <small><%= kindLabels[kind] || t('File') %> · <%= formatBytes(file.size) %></small>
                      </span>
                    </a>

                    <span class="explorer-file-cell explorer-file-date"><%= formatDate(file.created_at) %></span>
                    <span class="explorer-file-cell explorer-file-type"><%= kindLabels[kind] || t('File') %></span>
                    <span class="explorer-file-cell explorer-file-size"><%= formatBytes(file.size) %></span>
                    <span class="explorer-file-cell explorer-file-owner"><%= owner %></span>

                    <div class="explorer-file-actions">
                      <% if (repositoryPermissions.download) { %>
                        <a href="<%= downloadUrl %>" title="<%= t('Download') %>" aria-label="<%= t('Download {{name}}', { name: file.original_name }) %>">
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"/></svg>
                        </a>
                      <% } %>
                      <% if (repositoryPermissions.download || repositoryPermissions.delete) { %>
                        <details class="explorer-file-menu">
                          <summary title="<%= t('More options') %>" aria-label="<%= t('More actions for {{name}}', { name: file.original_name }) %>">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="5" cy="12" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/></svg>
                          </summary>
                          <div>
                            <% if (repositoryPermissions.download) { %>
                              <a href="<%= downloadUrl %>">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"/></svg>
                                <%= t('Download') %>
                              </a>
                            <% } %>
                            <% if (repositoryPermissions.delete) { %>
                              <form action="<%= deleteUrl %>" method="post" data-confirm="<%= t("Permanently delete '{{name}}'?", { name: file.original_name }) %>">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit">
                                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>
                                  <%= t('Delete') %>
                                </button>
                              </form>
                            <% } %>
                          </div>
                        </details>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              </div>

              <div class="explorer-filter-empty" data-filter-empty hidden>
                <span>⌕</span>
                <h3><%= t('No files match this category') %></h3>
                <p><%= t('Choose another file type or upload a new file.') %></p>
              </div>
            <% } else { %>
              <div class="explorer-zero-state">
                <span class="explorer-zero-icon" aria-hidden="true">
                  <svg viewBox="0 0 64 64"><path d="M8 18h18l6 7h24v27H8z"/><path d="M8 18v-5h18l6 7"/><path d="M24 38h16M32 30v16"/></svg>
                </span>
                <h2><%= search ? t('No search results') : t('This repository is empty') %></h2>
                <p><%= search ? t('Try another name or return to all files.') : t('Upload the first file to share it with the team.') %></p>
                <% if (search) { %>
                  <a class="button button-secondary" href="/repositories/<%= repository.id %>"><%= t('View all files') %></a>
                <% } else if (repositoryPermissions.upload) { %>
                  <button class="button button-primary" type="button" data-upload-open><%= t('Upload files') %></button>
                <% } %>
              </div>
            <% } %>

            <footer class="explorer-statusbar">
              <span><strong data-status-count><%= files.length %></strong> <span data-status-item-label><%= files.length === 1 ? t('item') : t('items') %></span></span>
              <span><%= t('{{size}} used', { size: formatBytes(stats.total_size) }) %></span>
            </footer>
          </section>

          <aside class="explorer-details-pane is-empty" data-details-pane aria-label="<%= t('File details') %>">
            <div class="explorer-details-empty" data-details-empty>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h4"/></svg>
              </span>
              <strong><%= t('Select a file') %></strong>
              <p><%= t('File type, size, uploader, and available actions will appear here.') %></p>
            </div>

            <div class="explorer-details-content" data-details-content hidden>
              <div class="explorer-details-heading">
                <span><%= t('File information') %></span>
                <button type="button" class="explorer-square-button" data-details-close aria-label="<%= t('Clear selection') %>" title="<%= t('Clear selection') %>">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"/></svg>
                </button>
              </div>

              <div class="explorer-details-tabs" role="tablist" aria-label="<%= t('File information tabs') %>">
                <button type="button" class="is-active" role="tab" aria-selected="true" data-details-tab="details"><%= t('Details') %></button>
                <button type="button" role="tab" aria-selected="false" data-details-tab="preview"><%= t('Preview') %></button>
              </div>

              <section class="explorer-details-panel" role="tabpanel" data-details-panel="details">
                <div class="explorer-details-preview">
                  <span class="file-icon explorer-details-icon" data-detail-icon aria-hidden="true">FILE</span>
                  <strong data-detail-name></strong>
                  <small data-detail-mime></small>
                </div>
                <dl class="explorer-details-list">
                  <div><dt><%= t('File type') %></dt><dd data-detail-type></dd></div>
                  <div><dt><%= t('Size') %></dt><dd data-detail-size></dd></div>
                  <div><dt><%= t('Uploaded') %></dt><dd data-detail-date></dd></div>
                  <div><dt><%= t('Uploader') %></dt><dd data-detail-owner></dd></div>
                </dl>
                <% if (repositoryPermissions.download || repositoryPermissions.delete) { %>
                  <div class="explorer-details-actions">
                    <% if (repositoryPermissions.download) { %><a class="button button-primary button-block" href="#" data-detail-download><%= t('Download') %></a><% } %>
                    <% if (repositoryPermissions.delete) { %>
                      <form action="#" method="post" data-detail-delete-form data-confirm="<%= t('Permanently delete the selected file?') %>">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="button button-danger button-block" type="submit"><%= t('Delete file') %></button>
                      </form>
                    <% } %>
                  </div>
                <% } %>
              </section>

              <section class="explorer-details-panel explorer-preview-panel" role="tabpanel" data-details-panel="preview" hidden>
                <div class="explorer-preview-stage" data-preview-stage>
                  <div class="explorer-preview-message" data-preview-message>
                    <span class="explorer-preview-message-icon" aria-hidden="true">PREVIEW</span>
                    <strong><%= t('Select the Preview tab to open this file.') %></strong>
                  </div>
                  <div class="explorer-preview-content" data-preview-content hidden></div>
                </div>
              </section>
            </div>
          </aside>
        </div>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
