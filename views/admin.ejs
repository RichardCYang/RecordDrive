<!doctype html>
<html lang="<%= language %>">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav') %>
  <main class="page-main">
    <div class="shell">
      <%- include('partials/flash') %>
      <section class="page-hero compact-hero">
        <div><span class="eyebrow"><%= t('ADMIN CONSOLE') %></span><h1><%= t('Admin dashboard') %></h1><p><%= t('Manage accounts, user-owned repositories, permission grants, and activity across RecordDrive.') %></p></div>
      </section>
      <%- include('partials/admin-tabs') %>

      <section class="metric-grid">
        <article class="metric-card"><span class="metric-label"><%= t('Member accounts') %></span><strong><%= metrics.users %></strong><small><%= t('Registered regular user accounts') %></small></article>
        <article class="metric-card"><span class="metric-label"><%= t('Repositories') %></span><strong><%= metrics.repositories %></strong><small><%= t('User-owned file spaces') %></small></article>
        <article class="metric-card"><span class="metric-label"><%= t('Files') %></span><strong><%= metrics.files %></strong><small><%= t('All uploaded files') %></small></article>
        <article class="metric-card"><span class="metric-label"><%= t('Storage used') %></span><strong><%= formatBytes(metrics.bytes) %></strong><small><%= t('Local disk usage') %></small></article>
      </section>

      <section class="panel">
        <div class="panel-header"><div><span class="eyebrow"><%= t('RECENT ACTIVITY') %></span><h2><%= t('Recent activity') %></h2></div></div>
        <% if (recentActivity.length) { %>
          <div class="activity-list">
            <% const labels = { LOGIN: t('Sign in activity'), CREATE_USER: t('Account created'), DELETE_USER: t('Account deleted'), CREATE_REPOSITORY: t('Repository created'), DELETE_REPOSITORY: t('Repository deleted'), GRANT_REPOSITORY_PERMISSION: t('Permission granted'), UPDATE_REPOSITORY_PERMISSION: t('Permission updated'), REVOKE_REPOSITORY_PERMISSION: t('Permission revoked'), UPLOAD_FILE: t('File uploaded'), DELETE_FILE: t('File deleted'), CREATE_FOLDER: t('Folder created'), DELETE_FOLDER: t('Folder deleted'), UPDATE_TLS_SETTINGS: t('HTTPS settings updated'), UPDATE_STORAGE_SETTINGS: t('Storage settings updated'), UPDATE_QUOTA_SETTINGS: t('Upload limits updated'), UPDATE_REPOSITORY_SETTINGS: t('Repository settings updated'), TOTP_ENABLED: t('Authenticator app enabled'), TOTP_DISABLED: t('Authenticator app disabled'), PASSKEY_REGISTERED: t('Passkey registered'), PASSKEY_REMOVED: t('Passkey removed'), RECOVERY_CODES_ADDED: t('Recovery keys added'), RECOVERY_CODES_REGENERATED: t('Recovery keys replaced') }; %>
            <% recentActivity.forEach((activity) => { %>
              <div class="activity-row">
                <span class="activity-icon"><%= activity.action.includes('DELETE') || activity.action === 'REVOKE_REPOSITORY_PERMISSION' ? '−' : activity.action === 'LOGIN' ? '↗' : '+' %></span>
                <div class="activity-copy"><strong><%= labels[activity.action] || activity.action %></strong><span><%= activity.target_label %></span></div>
                <div class="activity-meta"><span><%= activity.actor_name || t('Deleted account') %></span><time><%= formatDate(activity.created_at) %></time></div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="inline-empty"><%= t('No activity has been recorded yet.') %></div>
        <% } %>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
