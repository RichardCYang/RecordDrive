<!doctype html>
<html lang="<%= language %>">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav') %>
  <main class="page-main">
    <div class="shell">
      <%- include('partials/flash') %>
      <section class="page-hero compact-hero">
        <div>
          <a class="back-link" href="<%= isAdmin ? '/admin/repositories' : `/repositories/${repository.id}` %>"><%= t('← Back') %></a>
          <span class="eyebrow"><%= t('REPOSITORY PERMISSIONS') %></span>
          <h1><%= t('{{name}} access', { name: repository.name }) %></h1>
          <p><%= t('Grant each user only the repository actions they need. The owner and administrators always retain every permission.') %></p>
        </div>
        <a class="button button-secondary" href="/repositories/<%= repository.id %>"><%= t('Open repository') %></a>
      </section>

      <section class="permission-overview panel">
        <div>
          <span class="eyebrow"><%= t('OWNER') %></span>
          <strong><%= repository.owner_display_name || t('Deleted account') %></strong>
          <small><%= repository.owner_username ? `@${repository.owner_username}` : t('Ownership is currently unassigned.') %></small>
        </div>
        <div class="permission-help-grid">
          <span><strong><%= t('View') %></strong><small><%= t('Open the repository and see file metadata.') %></small></span>
          <span><strong><%= t('Upload') %></strong><small><%= t('Add files and folders through the repository.') %></small></span>
          <span><strong><%= t('Download') %></strong><small><%= t('Download stored file contents.') %></small></span>
          <span><strong><%= t('Delete') %></strong><small><%= t('Delete stored files.') %></small></span>
        </div>
      </section>

      <div class="permission-layout">
        <section class="panel sticky-panel">
          <div class="panel-header"><div><span class="eyebrow"><%= t('NEW GRANT') %></span><h2><%= t('Share with a user') %></h2></div></div>
          <form action="/repositories/<%= repository.id %>/permissions" method="post" class="stack-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label class="field">
              <span><%= t('User account') %></span>
              <input
                type="text"
                name="username"
                required
                minlength="3"
                maxlength="32"
                pattern="[a-z0-9_.-]{3,32}"
                placeholder="<%= t('Enter the exact username') %>"
                autocomplete="off"
                autocapitalize="none"
                spellcheck="false"
              >
              <small><%= t('Usernames are not listed to protect account privacy.') %></small>
            </label>
            <fieldset class="permission-fieldset">
              <legend><%= t('Allowed actions') %></legend>
              <label><input type="checkbox" name="canView" value="1"><span><strong><%= t('View') %></strong><small><%= t('Open and browse') %></small></span></label>
              <label><input type="checkbox" name="canUpload" value="1"><span><strong><%= t('Upload') %></strong><small><%= t('Add new files') %></small></span></label>
              <label><input type="checkbox" name="canDownload" value="1"><span><strong><%= t('Download') %></strong><small><%= t('Retrieve file data') %></small></span></label>
              <label class="permission-danger"><input type="checkbox" name="canDelete" value="1"><span><strong><%= t('Delete') %></strong><small><%= t('Files only') %></small></span></label>
            </fieldset>
            <button class="button button-primary button-block" type="submit"><%= t('Save permission grant') %></button>
          </form>
        </section>

        <section class="panel">
          <div class="panel-header"><div><span class="eyebrow"><%= t('CURRENT GRANTS') %></span><h2><%= t('Shared users') %> <span class="count-badge"><%= grants.length %></span></h2></div></div>
          <% if (grants.length) { %>
            <div class="permission-grant-list">
              <% grants.forEach((grant) => { %>
                <article class="permission-grant-row">
                  <div class="user-cell permission-user-cell">
                    <span class="avatar"><%= grant.display_name.slice(0, 1).toUpperCase() %></span>
                    <div><strong><%= grant.display_name %></strong><small>@<%= grant.username %> · <%= t('Updated') %> <%= formatDate(grant.updated_at) %></small></div>
                  </div>
                  <form action="/repositories/<%= repository.id %>/permissions/<%= grant.user_id %>" method="post" class="permission-inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <label title="<%= t('View') %>"><input type="checkbox" name="canView" value="1" <%= grant.can_view ? 'checked' : '' %>><span><%= t('View') %></span></label>
                    <label title="<%= t('Upload') %>"><input type="checkbox" name="canUpload" value="1" <%= grant.can_upload ? 'checked' : '' %>><span><%= t('Upload') %></span></label>
                    <label title="<%= t('Download') %>"><input type="checkbox" name="canDownload" value="1" <%= grant.can_download ? 'checked' : '' %>><span><%= t('Download') %></span></label>
                    <label class="permission-danger" title="<%= t('Delete') %>"><input type="checkbox" name="canDelete" value="1" <%= grant.can_delete ? 'checked' : '' %>><span><%= t('Delete') %></span></label>
                    <button class="button button-secondary button-small" type="submit"><%= t('Update') %></button>
                  </form>
                  <form action="/repositories/<%= repository.id %>/permissions/<%= grant.user_id %>/delete" method="post" data-confirm="<%= t('Revoke every permission for {{name}}?', { name: grant.display_name }) %>">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="button button-danger button-small" type="submit"><%= t('Revoke') %></button>
                  </form>
                </article>
              <% }) %>
            </div>
          <% } else { %><div class="inline-empty"><%= t('This repository has not been shared with another user.') %></div><% } %>
        </section>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
