<!doctype html>
<html lang="<%= language %>">
<head><%- include('partials/head') %></head>
<body class="login-page">
  <div class="sky-orb sky-orb-one"></div>
  <div class="sky-orb sky-orb-two"></div>
  <main class="login-shell">
    <section class="login-visual">
      <a class="brand brand-large" href="/login" aria-label="<%= t('RecordDrive home') %>">
        <%- include('partials/logo') %>
      </a>
      <div class="hero-copy">
        <span class="eyebrow"><%= t('TEAM CLOUD STORAGE') %></span>
        <h1><%= t('Keep every record organized,') %><br><em><%= t('securely together.') %></em></h1>
        <p><%= t('Organize files in team repositories and give access only to the people who need it.') %></p>
      </div>
      <div class="cloud-scene" aria-hidden="true">
        <div class="cloud cloud-a"></div>
        <div class="cloud cloud-b"></div>
        <div class="floating-folder">
          <svg viewBox="0 0 100 82"><path d="M8 23h31l9 10h44v39H8z"/><path d="M8 23V12h31l9 11"/></svg>
          <span class="folder-check">✓</span>
        </div>
      </div>
      <div class="login-feature-row">
        <span><%= t('Role-based access') %></span><span><%= t('File uploads') %></span><span><%= t('Activity history') %></span>
      </div>
    </section>

    <section class="login-panel">
      <div class="login-card">
        <div class="mobile-brand"><%- include('partials/logo') %></div>
        <div class="login-heading">
          <span class="eyebrow"><%= t('WELCOME BACK') %></span>
          <h2><%= t('Sign in to RecordDrive') %></h2>
          <p><%= t('Use the account provided by your administrator.') %></p>
        </div>

        <% if (error) { %>
          <div class="form-alert" role="alert"><%= error %></div>
        <% } %>

        <form action="/login" method="post" class="stack-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="returnTo" value="<%= returnTo %>">
          <label class="field">
            <span><%= t('Username') %></span>
            <div class="input-with-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 21a8 8 0 0 0-16 0M12 13a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z"/></svg>
              <input type="text" name="username" value="<%= username %>" placeholder="<%= t('Enter your username') %>" autocomplete="username" required autofocus>
            </div>
          </label>
          <label class="field">
            <span><%= t('Password') %></span>
            <div class="input-with-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 10V7a6 6 0 0 1 12 0v3M5 10h14v11H5z"/></svg>
              <input type="password" name="password" placeholder="<%= t('Enter your password') %>" autocomplete="current-password" required data-password-input>
              <button type="button" class="password-toggle" aria-label="<%= t('Show password') %>" data-password-toggle><%= t('Show') %></button>
            </div>
          </label>
          <button class="button button-primary button-block button-large" type="submit"><%= t('Sign in') %></button>
        </form>

        <div class="login-help"><%= t('Contact your RecordDrive administrator if you need an account or repository access.') %></div>
      </div>
    </section>
  </main>
  <%- include('partials/client-i18n') %>
</body>
</html>
